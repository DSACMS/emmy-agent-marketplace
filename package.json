{
  "name": "emmy-agent-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "Shared agent plugin and skill marketplace for the Emmy development team.",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "check": "pnpm run format:check && pnpm run lint && pnpm run validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run lint:markdown",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.cache\" \"#.venv\"",
    "secrets:scan": "gitleaks git --config .gitleaks.toml --redact .",
    "smoke:marketplace": "node scripts/smoke-marketplace.mjs",
    "validate": "pnpm run validate:json && pnpm run validate:marketplace",
    "validate:json": "node scripts/validate-json.mjs",
    "validate:marketplace": "node scripts/validate-marketplace.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.7.4",
    "yaml": "^2.8.2"
  }
}
